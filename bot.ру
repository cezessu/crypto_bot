# v2
import os
import io
import time
import random
import string
import telebot
from telebot import types
from flask import Flask, request
from PIL import Image, ImageDraw, ImageFont, ImageFilter

TOKEN = os.environ.get('BOT_TOKEN')
if not TOKEN:
    raise ValueError("BOT_TOKEN не найден в переменных окружения")

bot = telebot.TeleBot(TOKEN)
app = Flask(__name__)

# --- НАСТРОЙКИ ---
CHANNEL_USERNAME = "tradegrowthh"          # без @
PDF_FILENAME = "Фундаментальныеосновы.pdf"          # файл должен лежать в папке проекта

# Хранилище капчи: user_id -> {"answer": str, "attempts": int, "blocked_until": float or 0}
captcha_data = {}

# --- ГЕНЕРАТОР КАПЧИ С БУКВАМИ И ИСКАЖЕНИЯМИ ---
def generate_captcha_text(length=5):
    """Случайная строка из заглавных букв и цифр (без похожих)."""
    chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789'  # исключены I, O, 0, 1
    return ''.join(random.choices(chars, k=length))

def draw_captcha(text):
    """Создаёт искажённое изображение с текстом. Возвращает bytes."""
    W, H = 250, 90
    img = Image.new('RGB', (W, H), color=(240, 240, 240))
    draw = ImageDraw.Draw(img)

    # Фон с шумом
    for _ in range(random.randint(200, 400)):
        x = random.randint(0, W-1)
        y = random.randint(0, H-1)
        draw.point((x, y), fill=(random.randint(0, 180), random.randint(0, 180), random.randint(0, 180)))

    # Линии через всё изображение
    for _ in range(random.randint(3, 6)):
        x1 = random.randint(0, W)
        y1 = random.randint(0, H)
        x2 = random.randint(0, W)
        y2 = random.randint(0, H)
        draw.line([(x1, y1), (x2, y2)], fill=(random.randint(0, 120), random.randint(0, 120), random.randint(0, 120)), width=2)

    # Шрифт
    try:
        font = ImageFont.truetype("arial.ttf", 36)
    except:
        font = ImageFont.load_default()

    # Рисуем буквы по одной с поворотом и смещением
    x_offset = 15
    for ch in text:
        # Создаём временное изображение для поворота
        txt_img = Image.new('RGBA', (50, 60), (0, 0, 0, 0))
        txt_draw = ImageDraw.Draw(txt_img)
        txt_draw.text((5, 5), ch, font=font, fill=(random.randint(0, 80), random.randint(0, 80), random.randint(0, 80)))
        # Поворот
        angle = random.randint(-25, 25)
        rotated = txt_img.rotate(angle, expand=1, resample=Image.BICUBIC)
        # Вставляем на основное изображение
        img.paste(rotated, (x_offset, random.randint(10, 25)), rotated)
        x_offset += 35 + random.randint(5, 15)

    # Размытие для дополнительного искажения
    img = img.filter(ImageFilter.GaussianBlur(radius=0.8))

    buf = io.BytesIO()
    img.save(buf, format='PNG')
    buf.seek(0)
    return buf.getvalue()

def send_captcha(chat_id, attempts):
    """Отправляет новую капчу и обновляет данные."""
    text = generate_captcha_text()
    img_bytes = draw_captcha(text)
    captcha_data[chat_id] = {
        "answer": text,
        "attempts": attempts,
        "blocked_until": 0
    }
    bot.send_photo(chat_id, img_bytes, caption="Введите символы с картинки (заглавные буквы/цифры):")

def check_captcha(user_id, user_text):
    """Проверяет ответ и управляет блокировкой. Возвращает True, если капча пройдена."""
    if user_id not in captcha_data:
        return False
    data = captcha_data[user_id]
    # Проверка блокировки по времени
    if data["blocked_until"] > 0:
        if time.time() < data["blocked_until"]:
            remaining = int(data["blocked_until"] - time.time())
            bot.send_message(user_id, f"⏳ Вы исчерпали попытки. Попробуйте через {remaining} сек.")
            return False
        else:
            # Блокировка истекла, сбрасываем счётчик и удаляем текущую капчу (отправится новая)
            del captcha_data[user_id]
            return False

    # Сравнение без учёта регистра и пробелов
    if user_text.strip().upper() == data["answer"].upper():
        del captcha_data[user_id]
        return True
    else:
        data["attempts"] += 1
        if data["attempts"] >= 5:
            # Блокируем на 5 минут
            data["blocked_until"] = time.time() + 300
            bot.send_message(user_id, "❌ 5 неверных попыток. Доступ заблокирован на 5 минут.")
            return False
        else:
            remaining = 5 - data["attempts"]
            bot.send_message(user_id, f"❌ Неверно. Осталось попыток: {remaining}")
            # Отправляем новую капчу сразу
            send_captcha(user_id, data["attempts"])
            return False

# --- ВЕБХУКИ ---
@app.route('/' + TOKEN, methods=['POST'])
def getMessage():
    json_string = request.get_data().decode('utf-8')
    update = telebot.types.Update.de_json(json_string)
    bot.process_new_updates([update])
    return "!", 200

@app.route('/')
def webhook():
    render_host = os.environ.get('RENDER_EXTERNAL_HOSTNAME')
    if render_host:
        webhook_url = f'https://{render_host}/{TOKEN}'
        bot.remove_webhook()
        bot.set_webhook(url=webhook_url)
        return f"Webhook set to {webhook_url}", 200
    else:
        return "RENDER_EXTERNAL_HOSTNAME not set.", 500

# --- ТЕКСТЫ ---
WELCOME_TEXT = (
    "Приветствую)\n"
    "Первым 500 подписчикам дарю методичку по обучению крипто трейдинга! "
    "Никакой воды, только рабочие инструменты.\n"
    "Жми кнопку и успевай забрать знания бесплатно 📚 >>"
)
SUBSCRIBE_TEXT = "Подпишись на канал и получи методичку 👇"

def is_subscribed(user_id):
    try:
        member = bot.get_chat_member(f"@{CHANNEL_USERNAME}", user_id)
        return member.status in ['member', 'administrator', 'creator']
    except:
        return False

# --- ОБРАБОТЧИКИ ---
@bot.message_handler(commands=['start'])
def start_handler(message):
    # Сбрасываем предыдущее состояние, если было
    captcha_data.pop(message.chat.id, None)
    send_captcha(message.chat.id, 0)

# Обработчик текста только для тех, кто в процессе капчи
@bot.message_handler(func=lambda msg: msg.from_user.id in captcha_data and not msg.text.startswith('/'))
def captcha_input(message):
    user_id = message.from_user.id
    if check_captcha(user_id, message.text):
        # Капча пройдена, показываем основное меню
        markup = types.InlineKeyboardMarkup()
        btn_get = types.InlineKeyboardButton("📥 Забрать методичку", callback_data='request_pdf')
        markup.add(btn_get)
        bot.send_message(user_id, WELCOME_TEXT, reply_markup=markup)
    # Если капча не пройдена, check_captcha сама отправляет новую капчу или сообщение о блокировке

# Инлайн-кнопка "Забрать методичку"
@bot.callback_query_handler(func=lambda call: call.data == 'request_pdf')
def handle_request_pdf(call):
    markup = types.InlineKeyboardMarkup()
    btn_sub = types.InlineKeyboardButton("🔔 Подписаться на канал", url=f'https://t.me/{CHANNEL_USERNAME}')
    btn_check = types.InlineKeyboardButton("✅ Проверить подписку", callback_data='check_sub')
    markup.add(btn_sub, btn_check)
    bot.edit_message_text(
        chat_id=call.message.chat.id,
        message_id=call.message.message_id,
        text=SUBSCRIBE_TEXT,
        reply_markup=markup
    )
    bot.answer_callback_query(call.id)

# Проверка подписки и выдача PDF
@bot.callback_query_handler(func=lambda call: call.data == 'check_sub')
def handle_check_sub(call):
    user_id = call.from_user.id
    if is_subscribed(user_id):
        # Пробуем отправить PDF
        try:
            with open(PDF_FILENAME, 'rb') as f:
                bot.send_document(user_id, f, caption="🎉 Ваша методичка по крипто трейдингу! Спасибо за подписку.")
            # Удаляем старое сообщение с кнопками, чтобы не засорять
            bot.delete_message(call.message.chat.id, call.message.message_id)
        except FileNotFoundError:
            bot.send_message(user_id, "Извините, файл методички временно недоступен. Попробуйте позже.")
        bot.answer_callback_query(call.id, "Методичка отправлена!")
    else:
        bot.answer_callback_query(call.id, "❌ Вы ещё не подписались на канал.", show_alert=True)

